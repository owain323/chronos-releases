# CHRONOS PostgreSQL 连接配置
# 复制此文件为 .env 后填写

# 默认 SQLite（不设或设 sqlite）
DB_TYPE=postgres
DATABASE_URL=postgres://chronos:yourpassword@localhost:5432/chronos

# Docker 快速启动 PG 测试环境:
# docker run -d --name chronos-pg \
#   -e POSTGRES_USER=chronos \
#   -e POSTGRES_PASSWORD=yourpassword \
#   -e POSTGRES_DB=chronos \
#   -p 5432:5432 postgres:16
