# ============================================
# CHRONOS 环境变量配置
# 复制此文件为 .env 后填入真实值
# ============================================

# 运行模式：development | production | test
NODE_ENV=development

# 服务端口
PORT=3006

# 数据库地址
# SQLite（当前实现）: file:./chronos.db
# 架构支持 SQLite only — 迁移到 Postgres 需要改造 drizzle schema
DATABASE_URL=file:./chronos.db

# 应用标题
VITE_APP_TITLE=CHRONOS

# JWT 密钥（必填！）
# 生产环境: ≥32 字符随机字符串
# 开发环境: 任意值即可
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# 应用公网 URL（可选，用于机器人链接生成）
APP_URL=https://chronos.owain32380.cn

# ---- AI / LLM 大模型（可选，用于 AI 助手/AI Agent） ----
# 支持 OpenAI 兼容 API (DeepSeek/Qwen/Moonshot/OpenAI 均可)
# 小用户建议 deepseek-chat 降本
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# ---- 企微机器人（可选） ----
# 从企微管理后台 → 应用管理 → 机器人 → API 配置获取
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=

# ---- OAuth（当前未启用，留空） ----
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# ---- OpenTelemetry 全链路追踪（可选） ----
# 启用追踪: OTEL_ENABLED=true
# 归档后端 (如 Jaeger/Tempo/Grafana): OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# 服务名: OTEL_SERVICE_NAME=chronos
# 未配置 endpoint 时，dev 环境输出到 console，prod 环境丢弃
OTEL_ENABLED=false
OTEL_SERVICE_NAME=chronos
OTEL_EXPORTER_OTLP_ENDPOINT=
